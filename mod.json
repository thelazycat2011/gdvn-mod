{
  "geode": "5.6.1",
  "gd": {
    "win": "2.2081",
    "android": "2.2081",
    "mac": "2.2081",
    "ios": "2.2081"
  },
  "version": "5.0.4",
  "id": "nampe.gdvn",
  "name": "GDVN",
  "developer": "NamPE",
  "description": "GDVN helper mod",
  "links": {
    "homepage": "https://gdvn.net",
    "source": "https://github.com/Demon-List-VN/geode-mod",
    "community": "https://discord.gg/fybxJ9Y344"
  },
  "dependencies": {
    "legowiifun.cheat_api": {
      "version": ">=1.2.3",
      "required": true
    }
  },
  "settings": {
    "auth": {
      "type": "custom:auth",
      "name": "Authentication",
      "default": ""
    },
    "show-level-info": {
      "type": "bool",
      "name": "Show level info",
      "description": "Show level's list info",
      "default": true
    },
    "show-pvp-overlay": {
      "type": "bool",
      "name": "Show PvP overlay",
      "description": "Show realtime PvP progress while playing an active match",
      "default": true
    }
  }
}
